
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no"/>
<title>⚔️ Kingdom's Last Stand</title>
<style>
  *{margin:0;padding:0;box-sizing:border-box;}
  body{background:#0a0a14;display:flex;flex-direction:column;align-items:center;justify-content:center;min-height:100vh;font-family:'Segoe UI',sans-serif;overflow:hidden;}
  #gameCanvas{display:block;border:3px solid #a78bfa;border-radius:4px;box-shadow:0 0 40px rgba(167,139,250,0.4);}
  #ui{position:absolute;top:0;left:50%;transform:translateX(-50%);width:800px;pointer-events:none;}
</style>
</head>
<body>
<canvas id="gameCanvas" width="800" height="560"></canvas>
<script>
const C = document.getElementById('gameCanvas');
const ctx = C.getContext('2d');

// ── Responsive scaling ──────────────────────────────
function resize(){
  const s = Math.min(window.innerWidth/800, window.innerHeight/580, 1.4);
  C.style.width  = (800*s)+'px';
  C.style.height = (560*s)+'px';
}
window.addEventListener('resize', resize); resize();

// ── Constants ───────────────────────────────────────
const W=800, H=560;
const GROUND_Y = 420;
const COLORS = {
  sky1:'#1a0a2e', sky2:'#0d1b4b',
  ground:'#3d2b1f', grass:'#2d5a1b',
  castle:'#5a4a7a', castleLight:'#7a6a9a',
  player:'#e8d48b', sword:'#c0c0e0',
  goblin:'#4a7a3a', orc:'#3a5a2a',
  skeleton:'#d4d0c8', troll:'#6a8a4a',
  boss:'#8a2020', bossGlow:'#ff4040',
  hp:'#e74c3c', hpBg:'#2c1010',
  xp:'#f1c40f', xpBg:'#2c2410',
  wave:'#a78bfa', gold:'#f1c40f',
};

// ── Game State ──────────────────────────────────────
let gs;
function initGame(){
  gs = {
    state: 'menu', // menu | playing | paused | gameover | levelup
    frame: 0,
    score: 0,
    gold: 0,
    wave: 0,
    level: 1,
    waveTimer: 0,
    waveDelay: 180,
    waveActive: false,
    enemiesLeft: 0,
    player: makePlayer(),
    enemies: [],
    projectiles: [],
    particles: [],
    powerups: [],
    floats: [],
    castle: { hp: 200, maxHp: 200, x: 30, y: GROUND_Y-120, w: 90, h: 120 },
    keys: {},
    leaderboard: JSON.parse(localStorage.getItem('kls_lb')||'[]'),
    bossWarning: 0,
    screenShake: 0,
    pauseMenu: false,
    comboKills: 0,
    comboTimer: 0,
    upgrades: { damage:0, speed:0, range:0, regen:0 },
    upgradePoints: 0,
  };
  spawnWave();
}

function makePlayer(){
  return {
    x:200, y:GROUND_Y, w:36, h:48,
    vx:0, vy:0, onGround:true,
    hp:100, maxHp:100,
    facing:1, // 1=right, -1=left
    state:'idle', // idle|run|attack|jump|hurt|dead
    frame:0, frameTimer:0,
    attackTimer:0, attackCooldown:28,
    invincible:0,
    xp:0, xpToNext:100, playerLevel:1,
    baseDamage:18, baseSpeed:4.2,
    regen:0, regenTimer:0,
  };
}

// ── Input ───────────────────────────────────────────
const K={};
document.addEventListener('keydown',e=>{
  K[e.code]=true;
  if(e.code==='Escape' && gs.state==='playing'){ gs.state='paused'; }
  else if(e.code==='Escape' && gs.state==='paused'){ gs.state='playing'; }
  if(e.code==='KeyP') { if(gs.state==='playing') gs.state='paused'; else if(gs.state==='paused') gs.state='playing'; }
  e.preventDefault && (e.code==='Space' || e.code==='ArrowUp') && e.preventDefault();
});
document.addEventListener('keyup',e=>{ K[e.code]=false; });

// Touch controls
let touchJump=false, touchAtk=false, touchLeft=false, touchRight=false;
function addTouch(id, onDown, onUp){
  const el = document.getElementById(id);
  if(!el) return;
  el.addEventListener('touchstart',e=>{e.preventDefault();onDown();},{passive:false});
  el.addEventListener('touchend',e=>{e.preventDefault();onUp();},{passive:false});
  el.addEventListener('mousedown',onDown);
  el.addEventListener('mouseup',onUp);
}

// ── Wave spawning ────────────────────────────────────
function spawnWave(){
  gs.wave++;
  gs.waveActive = true;
  const isBoss = gs.wave % 5 === 0;
  if(isBoss) gs.bossWarning = 180;

  const count = isBoss ? 1 : Math.min(5 + gs.wave * 2 + gs.level * 2, 30);
  gs.enemiesLeft = count;

  for(let i=0;i<count;i++){
    setTimeout(()=>spawnEnemy(isBoss && i===0), i * (isBoss?0:320));
  }
}

function spawnEnemy(isBoss=false){
  if(isBoss){
    gs.enemies.push({
      type:'boss', x:W+60, y:GROUND_Y, w:80, h:100,
      hp: 300 + gs.level*100, maxHp:300+gs.level*100,
      spd:1.2+gs.level*0.1, dmg:20+gs.level*3,
      atk:0, atkCool:70, frame:0, frameTimer:0,
      reward:200+gs.level*50, xp:80, isBoss:true,
      phase:1, enraged:false,
    });
  } else {
    const types = ['goblin','orc','skeleton','troll'];
    const weights = [
      [1,0,0,0],[0.6,0.3,0.1,0],[0.4,0.3,0.2,0.1],
      [0.2,0.3,0.3,0.2],[0.1,0.2,0.4,0.3]
    ];
    const wIdx = Math.min(Math.floor(gs.wave/3), weights.length-1);
    const w = weights[wIdx];
    let r=Math.random(), t='goblin';
    if(r<w[0]) t='goblin'; else if(r<w[0]+w[1]) t='orc'; else if(r<w[0]+w[1]+w[2]) t='skeleton'; else t='troll';
    const stats = {
      goblin:  {w:24,h:32,hp:30+ gs.level*8, spd:2.8+gs.level*0.2,dmg:6+gs.level,atkCool:45,reward:10,xp:10},
      orc:     {w:34,h:42,hp:70+ gs.level*15,spd:2.0+gs.level*0.1,dmg:14+gs.level*2,atkCool:55,reward:20,xp:20},
      skeleton:{w:26,h:38,hp:45+ gs.level*10,spd:3.2+gs.level*0.2,dmg:10+gs.level,atkCool:40,reward:15,xp:15},
      troll:   {w:44,h:54,hp:120+gs.level*25,spd:1.5+gs.level*0.1,dmg:22+gs.level*3,atkCool:70,reward:35,xp:30},
    };
    const s = stats[t];
    gs.enemies.push({
      type:t, x:W+s.w, y:GROUND_Y,
      ...s, atk:0, frame:0, frameTimer:0,
      maxHp:s.hp, isBoss:false,
    });
  }
}

// ── Powerup Drop ─────────────────────────────────────
function dropPowerup(x,y){
  if(Math.random()>0.28) return;
  const types=['heal','speed','damage','shield','regen'];
  const t = types[Math.floor(Math.random()*types.length)];
  gs.powerups.push({x,y:y-20,t,vy:-3,life:300,bob:0});
}

// ── Particle Helpers ─────────────────────────────────
function burst(x,y,color,n=12,spd=4){
  for(let i=0;i<n;i++){
    const a=Math.random()*Math.PI*2;
    const s=Math.random()*spd+1;
    gs.particles.push({x,y,vx:Math.cos(a)*s,vy:Math.sin(a)*s-2,
      color,life:Math.random()*30+20,maxLife:50,size:Math.random()*5+2});
  }
}
function floatText(x,y,text,color='#fff',size=18){
  gs.floats.push({x,y,text,color,size,vy:-1.5,life:60,maxLife:60});
}

// ── Attack Logic ─────────────────────────────────────
function playerAttack(){
  const p=gs.player;
  if(p.attackTimer>0||p.state==='dead') return;
  p.state='attack'; p.attackTimer=p.attackCooldown;
  p.frame=0;
  const range = 80 + gs.upgrades.range*15;
  const dmg = Math.round(p.baseDamage * (1+gs.upgrades.damage*0.25));
  let hit=false;
  gs.enemies.forEach(e=>{
    const ex = e.x + e.w/2;
    const px = p.x + p.w/2;
    if(p.facing===1 && ex>px && ex<px+range){
      dealDamage(e, dmg); hit=true;
    } else if(p.facing===-1 && ex<px && ex>px-range){
      dealDamage(e, dmg); hit=true;
    }
  });
  if(hit){ burst(p.x+p.w/2+(p.facing*50), p.y-20, '#fff', 8, 3); }
}

function dealDamage(e, dmg){
  e.hp -= dmg;
  floatText(e.x+e.w/2, e.y-e.h, '-'+dmg, e.isBoss?'#ff8080':'#ff6060', e.isBoss?20:16);
  burst(e.x+e.w/2, e.y-e.h/2, '#ff6060', 6, 3);
  if(e.hp<=0) killEnemy(e);
  if(e.isBoss && e.hp<e.maxHp*0.5 && !e.enraged){
    e.enraged=true; e.spd*=1.6; e.atkCool=Math.floor(e.atkCool*0.6);
    floatText(e.x+e.w/2, e.y-e.h-20, 'ENRAGED!', '#ff4040', 22);
    gs.screenShake=20;
  }
}

function killEnemy(e){
  gs.score += e.reward * (1 + Math.floor(gs.comboKills/3));
  gs.gold  += Math.floor(e.reward/3);
  gs.player.xp += e.xp;
  gs.comboKills++;
  gs.comboTimer = 120;
  burst(e.x+e.w/2, e.y-e.h/2, e.isBoss?'#ff4040':'#f1c40f', e.isBoss?40:15, 5);
  if(e.isBoss){
    floatText(e.x+e.w/2, e.y-e.h-30, 'BOSS SLAIN!', '#ff8800', 26);
    gs.screenShake=40;
    // Drop guaranteed powerups
    for(let i=0;i<3;i++) gs.powerups.push({x:e.x+i*40,y:e.y-30,
      t:['heal','damage','speed'][i],vy:-4,life:400,bob:0});
  } else {
    dropPowerup(e.x+e.w/2, e.y-e.h/2);
  }
  e._dead=true;
  checkLevelUp();
}

function checkLevelUp(){
  const p=gs.player;
  while(p.xp>=p.xpToNext){
    p.xp-=p.xpToNext; p.playerLevel++;
    p.xpToNext=Math.floor(p.xpToNext*1.4);
    p.maxHp+=20; p.hp=Math.min(p.hp+30, p.maxHp);
    gs.upgradePoints++;
    floatText(p.x+p.w/2, p.y-p.h-10, 'LEVEL UP!', '#f1c40f', 22);
    burst(p.x+p.w/2, p.y-p.h/2, '#f1c40f', 20, 5);
    if(gs.upgradePoints>0) { gs.state='levelup'; }
  }
}

// ── UPDATE ───────────────────────────────────────────
function update(){
  if(gs.state!=='playing') return;
  gs.frame++;
  const p=gs.player;

  if(gs.bossWarning>0) gs.bossWarning--;
  if(gs.screenShake>0) gs.screenShake--;

  // Combo timer
  if(gs.comboTimer>0){ gs.comboTimer--; } else { gs.comboKills=0; }

  // Player regen
  if(gs.upgrades.regen>0){
    p.regenTimer++;
    if(p.regenTimer>180/(gs.upgrades.regen)){
      p.regenTimer=0;
      p.hp=Math.min(p.hp+1,p.maxHp);
    }
  }

  // Player input
  if(p.state!=='dead'){
    const spd = p.baseSpeed + gs.upgrades.speed*0.6;
    if(K['ArrowLeft']||K['KeyA']){ p.vx=-spd; p.facing=-1; if(p.state!=='attack') p.state='run'; }
    else if(K['ArrowRight']||K['KeyD']){ p.vx=spd; p.facing=1; if(p.state!=='attack') p.state='run'; }
    else { p.vx*=0.7; if(p.state==='run') p.state='idle'; }

    if((K['ArrowUp']||K['KeyW']||K['Space'])&&p.onGround){ p.vy=-13; p.onGround=false; p.state='jump'; }
    if(K['KeyF']||K['KeyZ']||K['KeyJ']) playerAttack();
    if(p.attackTimer>0){ p.attackTimer--; if(p.attackTimer===0 && p.state==='attack') p.state='idle'; }
  }

  // Physics
  p.x += p.vx;
  p.vy += 0.55;
  p.y += p.vy;
  if(p.y>=GROUND_Y){ p.y=GROUND_Y; p.vy=0; p.onGround=true; if(p.state==='jump') p.state='idle'; }
  p.x=Math.max(0, Math.min(W-p.w, p.x));
  if(p.invincible>0) p.invincible--;

  // Enemies
  gs.enemies = gs.enemies.filter(e=>!e._dead);
  gs.enemies.forEach(e=>{
    // Move toward player or castle
    const target = p.state!=='dead' ? p.x+p.w/2 : gs.castle.x+gs.castle.w;
    const ex = e.x+e.w/2;
    const dist = target-ex;
    if(Math.abs(dist)>e.w/2+p.w/2+4){
      e.x += e.spd * Math.sign(dist);
    } else {
      // Attack
      e.atk++;
      if(e.atk>=e.atkCool){
        e.atk=0;
        if(p.state!=='dead' && Math.abs(dist)<e.w/2+p.w/2+20){
          // Hit player
          if(p.invincible===0){
            p.hp -= e.dmg;
            p.invincible=40;
            p.state='hurt';
            gs.screenShake=10;
            burst(p.x+p.w/2,p.y-p.h/2,'#ff4444',8,3);
            floatText(p.x+p.w/2,p.y-p.h,'-'+e.dmg,'#ff4444');
            setTimeout(()=>{ if(p.state==='hurt') p.state='idle'; },300);
            if(p.hp<=0){ p.hp=0; p.state='dead'; endGame(); }
          }
        }
      }
    }
    // Hit castle
    if(e.x<gs.castle.x+gs.castle.w && e.x>gs.castle.x-10){
      e.atk++;
      if(e.atk>=e.atkCool){
        e.atk=0;
        gs.castle.hp-=e.dmg;
        gs.screenShake=8;
        burst(gs.castle.x+gs.castle.w/2,gs.castle.y+gs.castle.h/2,'#ff8800',6,3);
        if(gs.castle.hp<=0){ gs.castle.hp=0; endGame(); }
      }
    }
    e.frameTimer++; if(e.frameTimer>8){ e.frame=(e.frame+1)%4; e.frameTimer=0; }
    e.y=GROUND_Y;
  });

  // Check wave complete
  if(gs.waveActive && gs.enemies.length===0 && gs.enemiesLeft<=gs.enemies.length){
    // Delay: wait for all spawns to finish
    gs.waveTimer++;
    if(gs.waveTimer>240){
      gs.waveActive=false;
      gs.waveTimer=0;
      // Reward
      gs.score+=50*(gs.wave+gs.level);
      gs.gold+=20*gs.wave;
      floatText(W/2, H/2-40, 'Wave '+gs.wave+' Complete! +'+50*(gs.wave+gs.level)+' pts', '#a78bfa', 22);
      if(gs.wave%10===0){
        gs.level++;
        gs.castle.maxHp+=50; gs.castle.hp=Math.min(gs.castle.hp+50,gs.castle.maxHp);
        floatText(W/2, H/2-70, 'LEVEL '+gs.level+'!', '#f1c40f', 28);
      }
      setTimeout(()=>spawnWave(), 2500);
    }
  }

  // Powerups
  gs.powerups.forEach(pu=>{
    pu.vy+=0.2; pu.y+=pu.vy; pu.bob+=0.08;
    if(pu.y>GROUND_Y-16){ pu.y=GROUND_Y-16; pu.vy*=-0.3; }
    pu.life--;
    // Collect
    const px=p.x+p.w/2, py=p.y-p.h/2;
    if(Math.abs(px-(pu.x))<30 && Math.abs(py-(pu.y))<40){
      applyPowerup(pu.t);
      pu.life=0;
    }
  });
  gs.powerups=gs.powerups.filter(p=>p.life>0);

  // Particles
  gs.particles.forEach(pt=>{ pt.x+=pt.vx; pt.y+=pt.vy; pt.vy+=0.15; pt.life--; });
  gs.particles=gs.particles.filter(p=>p.life>0);

  // Float texts
  gs.floats.forEach(f=>{ f.y+=f.vy; f.life--; });
  gs.floats=gs.floats.filter(f=>f.life>0);
}

function applyPowerup(t){
  const p=gs.player;
  const msgs={heal:'❤️ +30 HP',speed:'⚡ Speed Up!',damage:'⚔️ Damage Up!',shield:'🛡️ Invincible!',regen:'💚 Regen!'};
  floatText(p.x+p.w/2,p.y-p.h-20,msgs[t],'#86efac',18);
  burst(p.x+p.w/2,p.y-p.h/2,'#86efac',16,4);
  if(t==='heal'){ p.hp=Math.min(p.hp+30,p.maxHp); }
  else if(t==='speed'){ p.baseSpeed=Math.min(p.baseSpeed+0.8,7); setTimeout(()=>p.baseSpeed=Math.max(p.baseSpeed-0.8,4.2),8000); }
  else if(t==='damage'){ p.baseDamage+=8; setTimeout(()=>p.baseDamage-=8,8000); }
  else if(t==='shield'){ p.invincible=300; }
  else if(t==='regen'){ gs.upgrades.regen=Math.min(gs.upgrades.regen+1,5); }
}

function endGame(){
  gs.state='gameover';
  const lb=gs.leaderboard;
  lb.push({score:gs.score,wave:gs.wave,level:gs.level,date:new Date().toLocaleDateString()});
  lb.sort((a,b)=>b.score-a.score);
  gs.leaderboard=lb.slice(0,10);
  localStorage.setItem('kls_lb',JSON.stringify(gs.leaderboard));
}

// ── DRAW ─────────────────────────────────────────────
function draw(){
  ctx.save();
  // Screen shake
  if(gs.screenShake>0){
    ctx.translate(
      (Math.random()-0.5)*gs.screenShake*0.6,
      (Math.random()-0.5)*gs.screenShake*0.4
    );
  }

  if(gs.state==='menu') { drawMenu(); ctx.restore(); return; }
  if(gs.state==='gameover') { drawGameOver(); ctx.restore(); return; }
  if(gs.state==='levelup') { drawGame(); drawLevelUp(); ctx.restore(); return; }

  drawGame();
  if(gs.state==='paused') drawPause();
  ctx.restore();
}

function drawGame(){
  // Sky gradient
  const sky=ctx.createLinearGradient(0,0,0,H);
  sky.addColorStop(0,'#0a0520'); sky.addColorStop(1,'#1a0a3a');
  ctx.fillStyle=sky; ctx.fillRect(0,0,W,H);

  // Stars
  ctx.fillStyle='rgba(255,255,255,0.7)';
  for(let i=0;i<80;i++){
    const sx=(i*137.5+gs.frame*0.02)%W;
    const sy=(i*73)%250;
    const ss=Math.sin(gs.frame*0.05+i)*0.5+0.8;
    ctx.globalAlpha=ss*0.8;
    ctx.fillRect(sx,sy,1.5,1.5);
  }
  ctx.globalAlpha=1;

  // Moon
  ctx.fillStyle='#fffde0';
  ctx.shadowColor='#fffde0'; ctx.shadowBlur=30;
  ctx.beginPath(); ctx.arc(700,60,28,0,Math.PI*2); ctx.fill();
  ctx.shadowBlur=0;

  // Mountains
  ctx.fillStyle='#1a0f30';
  [[0,300],[120,250],[250,280],[400,240],[550,270],[680,250],[750,280]].forEach(([mx,my])=>{
    ctx.beginPath(); ctx.moveTo(mx-80,GROUND_Y); ctx.lineTo(mx,my); ctx.lineTo(mx+80,GROUND_Y); ctx.fill();
  });

  // Ground
  ctx.fillStyle='#2d1f12';
  ctx.fillRect(0,GROUND_Y,W,H-GROUND_Y);
  ctx.fillStyle='#2d5a1b';
  ctx.fillRect(0,GROUND_Y,W,8);

  // Grass details
  ctx.fillStyle='#3a7a22';
  for(let i=0;i<W;i+=20){
    const h=4+Math.sin(i*0.3)*3;
    ctx.fillRect(i,GROUND_Y-h,3,h);
  }

  // Castle
  drawCastle();

  // Powerups
  gs.powerups.forEach(pu=>drawPowerup(pu));

  // Enemies
  gs.enemies.forEach(e=>drawEnemy(e));

  // Player
  drawPlayer();

  // Particles
  gs.particles.forEach(pt=>{
    ctx.globalAlpha=pt.life/pt.maxLife;
    ctx.fillStyle=pt.color;
    ctx.beginPath(); ctx.arc(pt.x,pt.y,pt.size,0,Math.PI*2); ctx.fill();
  });
  ctx.globalAlpha=1;

  // Float texts
  gs.floats.forEach(f=>{
    ctx.globalAlpha=f.life/f.maxLife;
    ctx.fillStyle=f.color;
    ctx.font=`bold ${f.size}px Segoe UI`;
    ctx.textAlign='center';
    ctx.shadowColor=f.color; ctx.shadowBlur=8;
    ctx.fillText(f.text,f.x,f.y);
    ctx.shadowBlur=0;
  });
  ctx.globalAlpha=1;

  // HUD
  drawHUD();

  // Boss warning
  if(gs.bossWarning>0){
    ctx.globalAlpha=Math.min(1,gs.bossWarning/60)*Math.abs(Math.sin(gs.frame*0.15));
    ctx.fillStyle='#ff4040';
    ctx.font='bold 36px Segoe UI';
    ctx.textAlign='center';
    ctx.shadowColor='#ff0000'; ctx.shadowBlur=20;
    ctx.fillText('⚠ BOSS INCOMING ⚠', W/2, H/2);
    ctx.shadowBlur=0; ctx.globalAlpha=1;
  }
}

function drawCastle(){
  const c=gs.castle;
  // Tower base
  ctx.fillStyle='#3d3050';
  ctx.fillRect(c.x, c.y, c.w, c.h);
  // Wall detail
  ctx.fillStyle='#4d4060';
  for(let row=0;row<4;row++){
    for(let col=0;col<3;col++){
      ctx.fillRect(c.x+col*30+4, c.y+row*28+4, 22, 20);
    }
  }
  // Battlements
  ctx.fillStyle='#5a4a7a';
  for(let i=0;i<4;i++){
    ctx.fillRect(c.x+i*22, c.y-18, 16, 20);
  }
  // Flag
  const ft=gs.frame*0.05;
  ctx.fillStyle='#e74c3c';
  ctx.beginPath();
  ctx.moveTo(c.x+44, c.y-32);
  ctx.lineTo(c.x+44+Math.sin(ft)*12+18, c.y-24+Math.cos(ft)*4);
  ctx.lineTo(c.x+44, c.y-16);
  ctx.fill();
  ctx.strokeStyle='#aaa'; ctx.lineWidth=2;
  ctx.beginPath(); ctx.moveTo(c.x+44,c.y-38); ctx.lineTo(c.x+44,c.y-8); ctx.stroke();
  // Gate
  ctx.fillStyle='#1a0f0a';
  ctx.beginPath();
  ctx.arc(c.x+c.w/2,c.y+c.h-24,16,Math.PI,0,false);
  ctx.fillRect(c.x+c.w/2-16,c.y+c.h-24,32,24);
