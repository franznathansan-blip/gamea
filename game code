  // Window
  ctx.fillStyle='#ffd700';
  ctx.globalAlpha=0.6+Math.sin(gs.frame*0.04)*0.3;
  ctx.beginPath(); ctx.arc(c.x+c.w/2, c.y+20,6,0,Math.PI*2); ctx.fill();
