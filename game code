function roundRect(ctx,x,y,w,h,r){
  ctx.beginPath();
  ctx.moveTo(x+r,y);
  ctx.lineTo(x+w-r,y); ctx.arcTo(x+w,y,x+w,y+r,r);
  ctx.lineTo(x+w,y+h-r); ctx.arcTo(x+w,y+h,x+w-r,y+h,r);
  ctx.lineTo(x+r,y+h); ctx.arcTo(x,y+h,x,y+h-r,r);
  ctx.lineTo(x,y+r); ctx.arcTo(x,y,x+r,y,r);
  ctx.closePath();
}

// ── Mouse ────────────────────────────────────────────
let _mouseX=0, _mouseY=0;
C.addEventListener('mousemove',e=>{
  const r=C.getBoundingClientRect();
  const sx=800/r.width, sy=560/r.height;
  _mouseX=(e.clientX-r.left)*sx;
  _mouseY=(e.clientY-r.top)*sy;
});
C.addEventListener('click',e=>{
  const r=C.getBoundingClientRect();
  const sx=800/r.width, sy=560/r.height;
  const mx=(e.clientX-r.left)*sx;
  const my=(e.clientY-r.top)*sy;

  if(gs.state==='menu'){
    if(mx>W/2-110 && mx<W/2+110 && my>450 && my<504){ initGame(); gs.state='playing'; }
  }
  else if(gs.state==='gameover'){
    if(mx>W/2-120 && mx<W/2+120 && my>425 && my<477){ initGame(); gs.state='playing'; }
    if(mx>W/2-120 && mx<W/2+120 && my>488 && my<532){ gs.state='menu'; }
  }
  else if(gs.state==='paused'){
    if(mx>W/2-110 && mx<W/2+110 && my>H/2 && my<H/2+50){ gs.state='playing'; }
  }
  // Leave button click (visible during playing & paused)
  if(gs.state==='playing'||gs.state==='paused'||gs.state==='levelup'){
    if(mx>W-90 && mx<W-10 && my>8 && my<36){ gs.state='menu'; }
  }
  else if(gs.state==='levelup'){
    const upgrades=['damage','speed','range','regen'];
    upgrades.forEach((id,i)=>{
      const bx=W/2-280+i*145, by=180;
      if(mx>bx && mx<bx+130 && my>by && my<by+160){
        gs.upgrades[id]++;
        gs.upgradePoints--;
        if(gs.upgradePoints<=0) gs.state='playing';
      }
    });
  }
});

// ── Game loop ─────────────────────────────────────────
function loop(){
  requestAnimationFrame(loop);
  update();
  draw();
  if(gs) gs.frame++;
}

// ── Boot ─────────────────────────────────────────────
gs = { state:'menu', frame:0, leaderboard: JSON.parse(localStorage.getItem('kls_lb')||'[]') };
loop();
</script>
