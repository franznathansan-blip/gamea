function drawPlayer(){
  const p=gs.player;
  ctx.save();
  ctx.translate(p.x+p.w/2, p.y);
  ctx.scale(p.facing,1);

  // Invincible flash
  if(p.invincible>0 && Math.floor(gs.frame/4)%2===0){ ctx.globalAlpha=0.4; }

  // Body
  ctx.fillStyle='#5a7abf'; // knight armor
  ctx.fillRect(-p.w/2, -p.h, p.w, p.h*0.65);
  // Helmet
  ctx.fillStyle='#7a9adf';
  ctx.fillRect(-p.w/2+2,-p.h,-p.w/2*0.8+2,p.h*0.32);
  ctx.beginPath(); ctx.arc(0,-p.h+p.h*0.15, p.w*0.42,Math.PI,0,false); ctx.fill();
  // Visor
  ctx.fillStyle='#333';
  ctx.fillRect(-4,-p.h+8,14,5);
  // Legs
  ctx.fillStyle='#3a5a9f';
  ctx.fillRect(-p.w/2,-p.h*0.35,p.w*0.44,p.h*0.35);
  ctx.fillRect(p.w*0.05,-p.h*0.35,p.w*0.44,p.h*0.35);
  // Boots
  ctx.fillStyle='#2a2a2a';
  ctx.fillRect(-p.w/2,-4,p.w*0.44,4);
  ctx.fillRect(p.w*0.05,-4,p.w*0.44,4);
  // Shield
  ctx.fillStyle='#8b0000';
  ctx.fillRect(-p.w/2-10,-p.h+10,10,24);
  ctx.fillStyle='#ff4444';
  ctx.beginPath(); ctx.arc(-p.w/2-5,-p.h+18,3,0,Math.PI*2); ctx.fill();

  // Sword swing
  const atkProgress = 1-(p.attackTimer/p.attackCooldown);
  const swordAngle = p.state==='attack'
    ? -Math.PI*0.6 + atkProgress*Math.PI*1.1
    : -Math.PI*0.4 + Math.sin(gs.frame*0.1)*0.1;
  ctx.save();
  ctx.translate(p.w/2-4,-p.h*0.6);
  ctx.rotate(swordAngle);
  // Blade
  ctx.fillStyle='#d4d8e8';
  ctx.fillRect(-2,-44,5,48);
  // Crossguard
  ctx.fillStyle='#b8860b';
  ctx.fillRect(-8,-6,20,5);
  // Handle
  ctx.fillStyle='#4a2800';
  ctx.fillRect(-2,0,5,14);
  // Glow on attack
  if(p.state==='attack'){
    ctx.shadowColor='#ffffff'; ctx.shadowBlur=15;
    ctx.fillStyle='rgba(255,255,200,0.4)';
    ctx.fillRect(-4,-50,10,56);
    ctx.shadowBlur=0;
  }
  ctx.restore();

  ctx.globalAlpha=1;
  ctx.restore();

  // XP bar
  const xpRatio=p.xp/p.xpToNext;
  ctx.fillStyle='#1a1a2a'; ctx.fillRect(10,H-22,200,12);
  ctx.fillStyle='#f1c40f'; ctx.fillRect(10,H-22,200*xpRatio,12);
  ctx.strokeStyle='#555'; ctx.lineWidth=1; ctx.strokeRect(10,H-22,200,12);
  ctx.fillStyle='#fff'; ctx.font='9px Segoe UI'; ctx.textAlign='left';
  ctx.fillText('LVL '+p.playerLevel+'  XP: '+p.xp+'/'+p.xpToNext, 14, H-12);
}

function drawEnemy(e){
  const colors={goblin:'#3a6a2a',orc:'#2a4a1a',skeleton:'#c4c0b8',troll:'#4a6a3a',boss:'#7a1010'};
  const light={goblin:'#5a9a4a',orc:'#4a7a2a',skeleton:'#e8e4dc',troll:'#6a9a5a',boss:'#aa3030'};
  ctx.save();
  ctx.translate(e.x+e.w/2, e.y);

  const bob = e.type!=='boss' ? Math.sin(gs.frame*0.15+e.x)*2 : Math.sin(gs.frame*0.08)*3;

  if(e.isBoss){
    // Boss glow
    ctx.shadowColor='#ff4040'; ctx.shadowBlur=20+Math.sin(gs.frame*0.1)*8;
    if(e.enraged){ ctx.shadowColor='#ff8000'; ctx.shadowBlur=35; }
  }

  // Body
  ctx.fillStyle=colors[e.type];
  ctx.fillRect(-e.w/2, -e.h+bob, e.w, e.h*0.7);
  // Head
  ctx.fillStyle=light[e.type];
  ctx.beginPath();
  ctx.arc(0,-e.h+bob+e.w*0.35, e.w*0.38,0,Math.PI*2); ctx.fill();

  if(e.type==='skeleton'){
    // Skull details
    ctx.fillStyle='#222';
    ctx.beginPath(); ctx.arc(-5,-e.h+bob+10,3,0,Math.PI*2); ctx.fill();
    ctx.beginPath(); ctx.arc(5,-e.h+bob+10,3,0,Math.PI*2); ctx.fill();
  } else if(e.type==='boss'||e.type==='troll'){
    // Horns
    ctx.fillStyle='#222';
    ctx.beginPath();
    ctx.moveTo(-e.w*0.3,-e.h+bob);
    ctx.lineTo(-e.w*0.2,-e.h+bob-18);
    ctx.lineTo(-e.w*0.1,-e.h+bob);
    ctx.fill();
    ctx.beginPath();
    ctx.moveTo(e.w*0.1,-e.h+bob);
    ctx.lineTo(e.w*0.2,-e.h+bob-18);
    ctx.lineTo(e.w*0.3,-e.h+bob);
    ctx.fill();
    // Eyes glow
    ctx.fillStyle='#ff4040';
    ctx.shadowColor='#ff0000'; ctx.shadowBlur=8;
    ctx.beginPath(); ctx.arc(-6,-e.h+bob+e.w*0.3,4,0,Math.PI*2); ctx.fill();
    ctx.beginPath(); ctx.arc(6,-e.h+bob+e.w*0.3,4,0,Math.PI*2); ctx.fill();
    ctx.shadowBlur=0;
  }

  // Weapon
  ctx.fillStyle='#555';
  ctx.save(); ctx.translate(e.w/2-4,-e.h+bob+e.h*0.4);
  if(e.type==='goblin'){ ctx.fillRect(0,-16,4,24); }
  else if(e.type==='orc'||e.type==='troll'){ ctx.fillRect(-4,-4,20,8); ctx.fillRect(6,-20,8,24); }
  else if(e.type==='skeleton'){ ctx.fillRect(0,-20,3,30); }
  else if(e.type==='boss'){
    ctx.fillStyle='#cc2200';
    ctx.fillRect(-4,-8,32,10);
    ctx.fillRect(12,-30,12,36);
  }
  ctx.restore();

  // Legs animation
  const legAnim=Math.sin(gs.frame*0.2)*6;
  ctx.fillStyle=colors[e.type];
  ctx.fillRect(-e.w/2+2,-e.h*0.3+bob, e.w*0.38, e.h*0.3+legAnim);
  ctx.fillRect(e.w*0.1+2,-e.h*0.3+bob, e.w*0.38, e.h*0.3-legAnim);

  ctx.shadowBlur=0;
  ctx.restore();

  // HP bar
  const bw=e.w+12, bh=5;
  const bx=e.x-6, by=e.y-e.h-10;
  ctx.fillStyle='#2c1010'; ctx.fillRect(bx,by,bw,bh);
  const ratio=e.hp/e.maxHp;
  ctx.fillStyle=ratio>0.5?'#2ecc71':ratio>0.25?'#f1c40f':'#e74c3c';
  ctx.fillRect(bx,by,bw*ratio,bh);
}

